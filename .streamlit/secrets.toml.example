# ── notebooklm secrets ─────────────────────────────────────────
# Copy to .streamlit/secrets.toml — never commit the real file.

# Ollama (local)
OLLAMA_BASE_URL   = "http://localhost:11434"
EMBEDDING_MODEL   = "nomic-embed-text"
DEFAULT_LLM_MODEL = "deepseek-r1:latest"
LLM_PROVIDER      = "ollama"   # ollama | openai | anthropic | groq

# Perplexity (web research)
PPLX_API_KEY = ""

# Cloud providers — add keys to enable each provider in the UI
OPENAI_API_KEY    = ""
ANTHROPIC_API_KEY = ""
GROQ_API_KEY      = ""

# Web Search (DuckDuckGo - no API key required)
# These control defaults; the user can override in the UI
WEB_SEARCH_MAX_RESULTS = "5"
WEB_SEARCH_MAX_FETCH   = "3"
WEB_SEARCH_REGION      = "wt-wt"   # "us-en", "uk-en", "in-en", etc.
