# ──────────────────────────────────────────────────────────────
# NotebookLM — Streamlit Secrets
# ──────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in values.
# NEVER commit secrets.toml to version control.
# ──────────────────────────────────────────────────────────────

# Perplexity Sonar API key (for web research feature)
PPLX_API_KEY = "your_perplexity_api_key_here"

# Ollama server URL (default: http://localhost:11434)
OLLAMA_BASE_URL = "http://localhost:11434"

# Embedding model — must be pulled in Ollama
EMBEDDING_MODEL = "nomic-embed-text"

# Default LLM model — used as fallback if model list is unavailable
DEFAULT_LLM_MODEL = "deepseek-r1:latest"
