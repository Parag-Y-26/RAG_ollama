# ── notebooklm secrets ─────────────────────────────────────────────────────
# Copy to .streamlit/secrets.toml — NEVER commit the real file.

# ── Ollama local ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL   = "http://localhost:11434"
EMBEDDING_MODEL   = "nomic-embed-text"
DEFAULT_LLM_MODEL = "deepseek-r1:latest"
LLM_PROVIDER      = "ollama"   # ollama | ollama_cloud | openai | anthropic | groq | nvidia

# ── Ollama Cloud ─────────────────────────────────────────────────────────────
# Create your API key at: https://ollama.com/settings/keys
# Cloud models: gpt-oss:120b-cloud, gpt-oss:20b-cloud,
#               deepseek-v3.1:671b-cloud, qwen3-coder:480b-cloud,
#               qwen3.5:397b-cloud
OLLAMA_API_KEY    = ""

# ── NVIDIA NIM ───────────────────────────────────────────────────────────────
# Mode 1: Hosted API Catalog (free tier available)
# Get a free key at https://build.nvidia.com/explore
# Keys always start with "nvapi-"
NVIDIA_API_KEY = ""

# Mode 2: Self-hosted local NIM container (no key needed)
# Run: docker run --gpus all -p 8000:8000 nvcr.io/nim/meta/llama-3.1-8b-instruct:latest
# Then set:
# NVIDIA_NIM_BASE_URL = "http://localhost:8000/v1"
# Leave NVIDIA_API_KEY empty when using self-hosted mode.
NVIDIA_NIM_BASE_URL = ""

# ── Third-party cloud providers ──────────────────────────────────────────────
OPENAI_API_KEY    = ""
ANTHROPIC_API_KEY = ""
GROQ_API_KEY      = ""

# ── Web research (Perplexity) ─────────────────────────────────────────────────
PPLX_API_KEY      = ""

# ── Web search settings ───────────────────────────────────────────────────────
WEB_SEARCH_MAX_RESULTS = "5"
WEB_SEARCH_MAX_FETCH   = "3"
WEB_SEARCH_REGION      = "wt-wt"   # "us-en", "uk-en", "in-en", etc.
